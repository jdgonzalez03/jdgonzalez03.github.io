---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";
import LinkToExternalIcon from "../components/icons/LinkToExternalIcon.astro";

const certificates = await getCollection("certificates");
---

<Layout>
  <main class="container mx-auto px-4 py-8 mt-20">
    <div class="max-w-2xl mx-auto section-animate">
      <h1 class="text-4xl font-extrabold mb-8 text-light-purple dark:text-dracula-purple">
        Certificados
      </h1>

      <div class="relative border-l border-light-purple/70 dark:border-dracula-purple/70">
        {
          certificates.map((cert, index) => (
            <div 
              class="mb-8 ms-8 relative stagger-item" 
              data-index={index}
            >
              <div class="absolute w-4 h-4 rounded-full -start-2 bg-light-purple dark:bg-dracula-purple border-2 border-light-background dark:border-dracula-background"></div>
              
              <div class="border rounded-xl p-6 hover:scale-[1.01] transition-transform bg-light-comment/20 dark:bg-dracula-comment/20 border-light-purple/30 dark:border-dracula-purple/30">
                <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4">
                  <div class="flex-1">
                    <h2 class="text-xl font-bold mb-2 text-light-foreground dark:text-dracula-foreground">
                      {cert.data.title}
                    </h2>
                    <time class="text-sm block mb-2 text-light-orange dark:text-dracula-orange">
                      {cert.data.date} - {cert.data.entity}
                    </time>
                    <p class="mb-4 text-light-foreground/70 dark:text-dracula-foreground/70">
                      {cert.data.description}
                    </p>
                  </div>
                  
                  {cert.data.link && (
                    <a
                      href={cert.data.link}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-flex items-center gap-2 px-4 py-2 text-sm rounded-lg border hover:scale-105 transition-transform whitespace-nowrap bg-light-comment/20 dark:bg-dracula-comment/20 border-light-purple dark:border-dracula-purple text-light-foreground dark:text-dracula-foreground"
                    >
                      <LinkToExternalIcon />
                      Ver Certificado
                    </a>
                  )}
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </main>
</Layout>
