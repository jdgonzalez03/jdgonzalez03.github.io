---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<Layout>
  <main class="container mx-auto px-4 py-8 mt-20 max-w-3xl">
    <a
      href="/blog"
      class="inline-flex items-center gap-2 mb-6 text-sm font-medium hover:underline"
      style="color: var(--accent-purple);"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      Volver al blog
    </a>

    <article>
      <header class="mb-8">
        <h1 class="text-4xl font-extrabold mb-4" style="color: var(--text-primary);">
          {post.data.title}
        </h1>
        <div class="flex flex-wrap items-center gap-4 mb-4">
          <time class="text-sm" style="color: var(--accent-orange);">
            {post.data.date.toLocaleDateString("es-ES", {
              year: "numeric",
              month: "long",
              day: "numeric",
            })}
          </time>
          <div class="flex flex-wrap gap-2">
            {post.data.tags.map((tag) => (
              <span class="px-2 py-1 text-xs rounded-full" style="background-color: var(--bg-secondary); color: var(--accent-purple);">
                {tag}
              </span>
            ))}
          </div>
        </div>
        {post.data.image && (
          <img
            src={post.data.image}
            alt={post.data.title}
            class="w-full h-64 object-cover rounded-xl"
          />
        )}
      </header>

      <div class="prose prose-lg max-w-none" style="color: var(--text-primary);">
        <Content />
      </div>
    </article>
  </main>
</Layout>

<style is:global>
  .prose h1,
  .prose h2,
  .prose h3,
  .prose h4 {
    color: var(--text-primary) !important;
    margin-top: 1.5em;
    margin-bottom: 0.5em;
  }

  .prose p {
    color: var(--text-secondary) !important;
    margin-bottom: 1em;
    line-height: 1.8;
  }

  .prose a {
    color: var(--accent-purple) !important;
    text-decoration: underline;
  }

  .prose code {
    background-color: var(--bg-secondary) !important;
    padding: 0.2em 0.4em;
    border-radius: 0.25em;
    font-size: 0.9em;
  }

  .prose pre {
    background-color: var(--bg-secondary) !important;
    border: 1px solid var(--border-color);
    border-radius: 0.5em;
    padding: 1em;
    overflow-x: auto;
  }

  .prose pre code {
    background-color: transparent !important;
    padding: 0;
  }

  .prose ul,
  .prose ol {
    color: var(--text-secondary) !important;
    margin-left: 1.5em;
    margin-bottom: 1em;
  }

  .prose li {
    margin-bottom: 0.5em;
  }

  .prose blockquote {
    border-left: 4px solid var(--accent-purple);
    padding-left: 1em;
    margin-left: 0;
    color: var(--text-secondary) !important;
    font-style: italic;
  }

  .prose strong {
    color: var(--text-primary) !important;
  }
</style>
