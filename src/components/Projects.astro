---
import DemoIcon from "./icons/Demo.astro";
import GithubIcon from "./icons/Github.astro";
const projects = [
  {
    title: "Próximamente",
    description:
      "Esta sección de proyectos está en desarrollo. Pronto compartiré algunos de mis trabajos realizados con Wagtail, Django y Vue JS.",
    image: "/cat-type.gif",
    linkRepo: "#",
    linkDemo: "#",
    technologies: ["Wagtail", "Django", "Vue JS"],
  },
];
---

{
  projects.map((project) => (
    <article class="mb-8 flex flex-col md:flex-row border rounded-xl overflow-hidden hover:scale-105 hover:shadow-lg transition-all duration-300 bg-dracula-background/50 dark:bg-dracula-background/50 border-dracula-purple/30 dark:border-dracula-purple/30">
      <div class="md:w-1/3 relative">
        <img
          class="w-full h-full object-cover aspect-video md:aspect-auto"
          loading="lazy"
          src={project.image}
          alt={project.title}
        />
      </div>
      <div class="md:w-2/3 p-6 flex flex-col justify-between">
        <div>
          <h3 class="text-xl font-bold mb-3 text-dracula-foreground dark:text-dracula-foreground">
            {project.title}
          </h3>
          <div class="flex flex-wrap gap-2 mb-6">
            {project.technologies.map((tech) => (
              <span class="px-3 py-1 bg-dracula-green/20 dark:bg-dracula-green/20 text-dracula-green dark:text-dracula-green border border-dracula-green dark:border-dracula-green rounded-full text-xs">
                {tech}
              </span>
            ))}
          </div>
          <p class="text-dracula-foreground/80 dark:text-dracula-foreground/80 mb-4">{project.description}</p>
        </div>
        <div class="flex gap-4">
          <a
            href={project.linkRepo}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center px-4 py-2 text-sm rounded-md bg-dracula-comment/20 dark:bg-dracula-comment/20 border border-dracula-purple dark:border-dracula-purple text-dracula-foreground dark:text-dracula-foreground hover:bg-dracula-comment/30 dark:hover:bg-dracula-comment/30 hover:text-dracula-purple dark:hover:text-dracula-purple hover:border-dracula-purple dark:hover:border-dracula-purple hover:scale-105 transition-all duration-300"
          >
            <GithubIcon />
            Código
          </a>
          <a
            href={project.linkDemo}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center px-4 py-2 bg-dracula-yellow/30 dark:bg-dracula-yellow/30 border border-dracula-yellow dark:border-dracula-yellow text-dracula-yellow dark:text-dracula-yellow rounded-lg hover:bg-dracula-yellow/40 dark:hover:bg-dracula-yellow/40 hover:scale-105 transition-colors duration-200"
          >
            <DemoIcon />
            Demo
          </a>
        </div>
      </div>
    </article>
  ))
}
