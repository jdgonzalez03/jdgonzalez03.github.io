---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
---

<!doctype html>
<html lang="es" class="h-full">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image" href="/me.webp" />
		<meta name="generator" content={Astro.generator} />
		<meta name="author" content="Juan Gonzalez" />
		<meta name="title" content="Juan Gonzalez - Desarrollador Web" />
		<meta name="description" content="Este es mi sitio web personal, donde comparto mis pensamientos y proyectos. Soy un desarrollador web apasionado por construir sitios web hermosos y funcionales." />
		<meta name="keywords" content="blog, astro, juan gonzalez, portfolio, web developer" />
		<meta property="og:image" content="https://jdgonzalez03.github.io/me.webp" />
		<meta property="og:title" content="Juan Gonzalez - Desarrollador Web" />
		<meta property="og:description" content="Desarrollador web full stack con una pasión por la tecnología y el desarrollo de software. Cuento con 11 meses de experiencia construyendo aplicaciones web utilizando tecnologías modernas como Django para el backend y Vue.js con Composition API para el frontend. Actualmente resido en Villavicencio, Colombia." />
		<meta property="og:url" content="https://jdgonzalez03.github.io/" />
		<title>Juan Gonzalez - Desarrollador Web</title>
		<script is:inline>
			(function() {
				const theme = localStorage.getItem("theme") || (window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light");
				document.documentElement.classList.add(theme);
			})();
		</script>
	</head>
	<body class="min-h-full antialiased pt-4 transition-colors duration-300 flex flex-col">
		<Header>
			<ThemeToggle slot="theme-toggle" />
		</Header>
		<main class="container flex-1 mx-auto px-4 py-8">
			<slot />
		</main>
		<Footer />
		<script>
			import gsap from "gsap";
			import { ScrollTrigger } from "gsap/ScrollTrigger";
			gsap.registerPlugin(ScrollTrigger);

			window.addEventListener("DOMContentLoaded", () => {
				// Header animation
				gsap.from("header", {
					y: -100,
					opacity: 0,
					duration: 0.8,
					ease: "power3.out"
				});

				// Section animations with stagger
				gsap.utils.toArray(".section-animate").forEach((el, i) => {
					gsap.from(el as HTMLElement, {
						y: 50,
						opacity: 0,
						duration: 0.8,
						delay: i * 0.1,
						ease: "power3.out",
						scrollTrigger: {
							trigger: el as HTMLElement,
							start: "top 85%",
							toggleActions: "play none none none"
						}
					});
				});

				// Staggered animations for cards/items
				gsap.utils.toArray(".stagger-item").forEach((el, i) => {
					gsap.from(el as HTMLElement, {
						y: 30,
						opacity: 0,
						duration: 0.5,
						delay: i * 0.1,
						ease: "power2.out",
						scrollTrigger: {
							trigger: el as HTMLElement,
							start: "top 90%",
							toggleActions: "play none none none"
						}
					});
				});

				// Footer animation
				gsap.from(".footer-animate", {
					y: 60,
					opacity: 0,
					duration: 1,
					ease: "power3.out",
					scrollTrigger: {
						trigger: ".footer-animate",
						start: "top bottom",
						toggleActions: "play none none none"
					},
					onComplete: () => {
						gsap.set(".footer-animate", { clearProps: "all" });
					}
				});
			});
		</script>
	</body>
</html>
