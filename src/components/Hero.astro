---
import MailIcon from "./icons/Mail.astro";
import LinkedInIcon from "./icons/Linkedin.astro";
import SocialLink from "./SocialLink.astro";
import GithubIcon from "./icons/Github.astro";

const altName = "Juan Gonzalez";

const isAvailable = true;
---

<div class="max-w-2xl">
  <div class="flex gap-4 items-center mb-4">
    <img
      src="/me.webp"
      alt={altName}
      class="rounded-full shadow-lg size-24 object-cover"
    />
    <div class="flex flex-col gap-2">
      <span
        class="text-xs font-medium ml-2 px-4 py-2 rounded-full cursor-pointer hover:scale-105 transition-all duration-200 ease-in-out"
        style="background-color: color-mix(in srgb, var(--accent-green) 10%, transparent); border: 1px solid color-mix(in srgb, var(--accent-green) 80%, transparent); color: var(--accent-green);"
      >
        Disponible para trabajar
      </span>
    </div>
  </div>

  <h1 class="text-4xl mb-2 font-extrabold" style="color: var(--text-primary);">
    <span
      class="bg-clip-text text-transparent bg-gradient-to-r"
      style="background-image: linear-gradient(to right, var(--accent-pink), var(--accent-purple));"
    >
      Soy, Juan Gonzalez
    </span>
  </h1>
  <p class="text-lg" style="color: var(--text-secondary);">
    Desarrollador <span class="font-bold" style="color: var(--accent-cyan);">web full stack</span> con una pasión por la tecnología
    y el desarrollo de software. Cuento con <span class="font-bold" style="color: var(--accent-orange);">13 meses de experiencia</span> trabajando
    en el desarrollo de aplicaciones web, utilizando tecnologías modernas como <span class="font-bold" style="color: var(--accent-green);">Django</span
    > para el backend y <span class="font-bold" style="color: var(--accent-yellow);">Vue.js</span> con Composition API para el frontend.
      Actualmente resido en <span class="font-bold" style="color: var(--accent-purple);">Villavicencio, Colombia</span>.
  </p>

  <nav class="flex flex-wrap gap-4 mt-8">
    <SocialLink href="mailto:juandavidgonzalezurrego@gmail.com">
      <MailIcon class="size-4" />
      Contáctame
    </SocialLink>
    <SocialLink href="https://www.linkedin.com/in/juan-gonzalez-067aa728b/">
      <LinkedInIcon class="size-4" />
      LinkedIn
    </SocialLink>
    <SocialLink href="https://github.com/jdgonzalez03">
      <GithubIcon class="size-4" />
      GitHub
    </SocialLink>
  </nav>
</div>
