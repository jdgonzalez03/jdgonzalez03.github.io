---
const email = "juandavidgonzalezurrego@gmail.com";
---

<form id="contact-form" class="space-y-4">
  <div class="grid md:grid-cols-2 gap-4">
    <div>
      <label for="name" class="block text-sm font-medium mb-2 text-light-foreground/70 dark:text-dracula-foreground/70">
        Nombre
      </label>
      <input
        type="text"
        id="name"
        name="name"
        required
        class="w-full px-4 py-2 rounded-lg border focus:outline-none focus:ring-2 transition-all bg-light-comment/20 dark:bg-dracula-comment/20 border-light-purple/30 dark:border-dracula-purple/30 text-light-foreground dark:text-dracula-foreground"
        placeholder="Tu nombre"
      />
    </div>
    <div>
      <label for="email" class="block text-sm font-medium mb-2 text-light-foreground/70 dark:text-dracula-foreground/70">
        Email
      </label>
      <input
        type="email"
        id="email"
        name="email"
        required
        class="w-full px-4 py-2 rounded-lg border focus:outline-none focus:ring-2 transition-all bg-light-comment/20 dark:bg-dracula-comment/20 border-light-purple/30 dark:border-dracula-purple/30 text-light-foreground dark:text-dracula-foreground"
        placeholder="tu@email.com"
      />
    </div>
  </div>

  <div>
    <label for="subject" class="block text-sm font-medium mb-2 text-light-foreground/70 dark:text-dracula-foreground/70">
      Asunto
    </label>
    <input
      type="text"
      id="subject"
      name="subject"
      required
      class="w-full px-4 py-2 rounded-lg border focus:outline-none focus:ring-2 transition-all bg-light-comment/20 dark:bg-dracula-comment/20 border-light-purple/30 dark:border-dracula-purple/30 text-light-foreground dark:text-dracula-foreground"
      placeholder="Asunto del mensaje"
    />
  </div>

  <div>
    <label for="message" class="block text-sm font-medium mb-2 text-light-foreground/70 dark:text-dracula-foreground/70">
      Mensaje
    </label>
    <textarea
      id="message"
      name="message"
      rows="4"
      required
      class="w-full px-4 py-2 rounded-lg border focus:outline-none focus:ring-2 transition-all resize-none bg-light-comment/20 dark:bg-dracula-comment/20 border-light-purple/30 dark:border-dracula-purple/30 text-light-foreground dark:text-dracula-foreground"
      placeholder="Escribe tu mensaje..."
    ></textarea>
  </div>

  <button
    type="submit"
    class="w-full py-3 px-6 rounded-lg font-medium transition-all duration-200 hover:scale-[1.02] bg-dracula-purple dark:bg-dracula-purple text-dracula-background dark:text-dracula-background"
  >
    Enviar Mensaje
  </button>
</form>

<script is:inline>
  const email = "juandavidgonzalezurrego@gmail.com";
  const form = document.getElementById("contact-form");

  form?.addEventListener("submit", (e) => {
    e.preventDefault();

    const nameInput = document.getElementById("name");
    const emailInput = document.getElementById("email");
    const subjectInput = document.getElementById("subject");
    const messageInput = document.getElementById("message");

    const name = nameInput?.value || "";
    const mail = emailInput?.value || "";
    const subject = subjectInput?.value || "";
    const message = messageInput?.value || "";

    const mailtoLink = `mailto:${email}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(`Nombre: ${name}\nEmail: ${mail}\n\nMensaje:\n${message}`)}`;

    window.location.href = mailtoLink;
  });
</script>
