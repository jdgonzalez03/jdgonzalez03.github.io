---
import CloseIcon from "./icons/CloseIcon.astro";
import OpenIcon from "./icons/OpenIcon.astro";

const currentPath = Astro.url.pathname;

const links = [
  {
    title: "Inicio",
    label: "inicio",
    href: "/",
  },
  {
    title: "Blog",
    label: "blog",
    href: "/blog",
  },
  {
    title: "Proyectos",
    label: "proyectos",
    href: "/projects",
  },
  {
    title: "Certificados",
    label: "certificados",
    href: "/certificates",
  },
];
---

<header id="main-header" class="w-full flex justify-center items-center fixed top-0 z-50 mt-2 transition-transform duration-300 ease-out">
  <nav
    class="mt-2 backdrop-blur-sm border-2 rounded-full px-4 py-3 flex items-center justify-between gap-4 bg-light-comment/20 dark:bg-dracula-comment/20 border-light-purple/30 dark:border-dracula-purple/30"
  >
    <div class="hidden md:flex items-center gap-4">
      {
        links.map((link) => (
          <a
            href={link.href}
            aria-label={link.label}

            class={ link.href === currentPath ? 
              `px-2 text-sm font-bold hover:scale-110 transition-all duration-200 ease-in-out text-light-foreground/80 dark:text-dracula-foreground/80 hover:text-light-purple dark:hover:text-dracula-purple text-light-purple dark:text-dracula-purple` : `px-2 text-sm font-bold hover:scale-110 transition-all duration-200 ease-in-out text-light-foreground/80 dark:text-dracula-foreground/80 hover:text-light-purple dark:hover:text-dracula-purple`}
          >
            {link.title}
          </a>
        ))
      }
    </div>

    <button
      id="mobile-menu-btn"
      class="md:hidden p-2 rounded-full focus:outline-none text-light-foreground/80 dark:text-dracula-foreground/80"
      aria-label="Abrir menú"
      aria-expanded="false"
    >
      <div id="menu-icon" class="block">
        <OpenIcon />
      </div>
      <div id="close-icon" class="hidden">
        <CloseIcon />
      </div>
    </button>

    <slot name="theme-toggle" />
  </nav>
</header>

<div
  id="mobile-menu"
  class="fixed inset-0 z-40 hidden md:hidden bg-light-background dark:bg-dracula-background"
>
  <div class="flex flex-col items-center justify-center h-full gap-8">
    {
      links.map((link) => (
        <a
          href={link.href}
          aria-label={link.label}
          class={ link.href === currentPath ? 
              "text-2xl font-bold hover:scale-110 transition-all duration-200 text-light-purple dark:text-dracula-purple" : "text-2xl font-bold hover:scale-110 transition-all duration-200 text-light-foreground dark:text-dracula-foreground"}
        >
          {link.title}
        </a>
      ))
    }
  </div>
</div>

<style>
  #mobile-menu a:hover {
    color: var(--accent-purple) !important;
  }
</style>

<script>
  const menuBtn = document.getElementById("mobile-menu-btn");
  const mobileMenu = document.getElementById("mobile-menu");
  const menuIcon = document.getElementById("menu-icon");
  const closeIcon = document.getElementById("close-icon");

  const toggleMenu = () => {
    const isOpen = mobileMenu?.classList.toggle("hidden") === false;
    
    if (menuIcon && closeIcon) {
      if (isOpen) {
        menuIcon.classList.add("hidden");
        closeIcon.classList.remove("hidden");
      } else {
        menuIcon.classList.remove("hidden");
        closeIcon.classList.add("hidden");
      }
    }

    if (menuBtn) {
      menuBtn.setAttribute("aria-expanded", String(isOpen));
    }
  };

  menuBtn?.addEventListener("click", toggleMenu);

  mobileMenu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      toggleMenu();
    });
  });
</script>
